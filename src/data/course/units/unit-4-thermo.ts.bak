B8700" opacity="0.5"/> <text x="19" y="26" font-size="6" fill="#334155" font-weight="bold">2</text> <circle cx="50" cy="14" r="2.5" fill="#3B8700" opacity="0.5"/> <text x="53" y="12" font-size="6" fill="#334155" font-weight="bold">3</text> <circle cx="50" cy="62" r="2.5" fill="#3B8700" opacity="0.5"/> <text x="53" y="66" font-size="6" fill="#334155" font-weight="bold">4</text> <!-- Direction arrows --> <polygon points="22.5,44 24,40 25.5,44" fill="#3B8700" opacity="0.3"/> <polygon points="38,18 42,17 40,21" fill="#3B8700" opacity="0.3"/> <polygon points="48.5,40 50,44 51.5,40" fill="#3B8700" opacity="0.3"/> <polygon points="37,60.5 33,62 37,63.5" fill="#3B8700" opacity="0.3"/> <!-- Process labels --> <text x="16" y="46" font-size="3.5" fill="#6B7280">Pump</text> <text x="32" y="14" font-size="3.5" fill="#6B7280">Boiler</text> <text x="54" y="40" font-size="3.5" fill="#6B7280">Turb.</text> <text x="33" y="68" font-size="3.5" fill="#6B7280">Cond.</text> <!-- Tracing dot --> <circle r="3" fill="#3B8700" opacity="0.6"> <animateMotion dur="5s" repeatCount="indefinite" path="M24,62 L24,28 Q28,26 32,24 Q40,20 50,14 L50,62 L24,62"/> </circle> <circle r="1.2" fill="white" opacity="0.4"> <animateMotion dur="5s" repeatCount="indefinite" path="M24,62 L24,28 Q28,26 32,24 Q40,20 50,14 L50,62 L24,62"/> </circle> </svg>',
