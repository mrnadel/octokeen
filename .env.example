# ===========================================
# MechReady Environment Variables
# Copy this file to .env.local and fill in values
# ===========================================

# --- Database (Vercel Postgres / Neon) ---
POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/dbname?sslmode=require

# --- NextAuth ---
AUTH_SECRET=generate-a-random-secret-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# --- Google OAuth ---
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# --- Paddle (server-side — NEVER prefix with NEXT_PUBLIC_) ---
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
PADDLE_PRO_MONTHLY_PRICE_ID=pri_xxx
PADDLE_PRO_YEARLY_PRICE_ID=pri_xxx

# --- Paddle (client-side — safe to expose) ---
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token
NEXT_PUBLIC_PADDLE_PRO_MONTHLY_PRICE_ID=pri_xxx
NEXT_PUBLIC_PADDLE_PRO_YEARLY_PRICE_ID=pri_xxx

# --- Mixpanel (client-side — project token, safe to expose) ---
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_project_token

# --- Admin ---
ADMIN_USER_ID=your-admin-user-uuid
NEXT_PUBLIC_ADMIN_USER_ID=your-admin-user-uuid
